# ============================================================
# FlowLog — exemplo de configuração
# ============================================================
# Copie este arquivo para .env e preencha os valores.
# Nunca commite o .env real; este template é versionado.
# ============================================================

# --- Banco de dados ---
DB_HOST=localhost
DB_USER=flowlog
DB_PASSWORD=change-me
DB_NAME=flowlog

# --- Logging ---
# Nível mínimo para o console: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Sessão / Lockout ---
# Auto-logout por inatividade, em minutos. 0 = desabilitado.
SESSION_TIMEOUT_MINUTES=30

# Tentativas falhas antes de bloquear a conta.
LOCKOUT_MAX_ATTEMPTS=5

# Duração do bloqueio, em minutos.
LOCKOUT_DURATION_MINUTES=15

# --- Backup ---
# Quantos backups manter localmente (0 = sem retenção, nunca apaga).
BACKUP_MAX_RETENTION=30
